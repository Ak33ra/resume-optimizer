# ============================================================================
#  PRIVACY GUARDRAIL  —  read PRIVACY.md
#  This repo is a PUBLIC skeleton. The paths below hold PII (your resumes and
#  source material) and are ignored BY DEFAULT so a stray `git add .` can never
#  stage them. The tracked `*.example.md` files and READMEs are safe templates.
# ============================================================================
resumes/*
!resumes/README.md
!resumes/*.example.json

outputs/*
!outputs/README.md

source_material/*
!source_material/README.md
!source_material/*.example.md

job_targets.csv
job_descriptions/*
!job_descriptions/README.md
!job_descriptions/*.example.md

# ----------------------------------------------------------------------------
#  PRIVATE FORK ONLY  —  keeping a personal, version-controlled history of your
#  real resumes, source material, and selected job targets.
#  Do this ONLY inside your OWN PRIVATE repo (its `origin` is a private remote —
#  see PRIVACY.md). NEVER in a clone of the public skeleton.
#  To turn it on, uncomment the two lines below (later rules override earlier
#  ones, so this un-ignores your real files), then run once:
#      git config resumeopt.allowPII true
#      git config resumeopt.privateRemote origin
#      git config resumeopt.privatePushUrl "$(git remote get-url --push origin)"
#  Alternatively, leave these commented and `git add -f` files deliberately.
# ----------------------------------------------------------------------------
# !resumes/*
# !outputs/*
# !source_material/*
# !job_targets.csv
# !job_descriptions/*

# ============================================================================
#  Benchmarks — keep personal data & run outputs local
# ============================================================================
benchmarks/ground_truth/*
!benchmarks/ground_truth/*.example.yaml
benchmarks/results/*
!benchmarks/results/.gitkeep
benchmarks/external/*
!benchmarks/external/.gitkeep

# ============================================================================
#  Build artifacts & cruft (always ignored)
# ============================================================================
*.aux
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.toc
*.bbl
*.blg
*.run.xml
/resume_template.pdf

.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/
.venv/
__pycache__/
*.pyc
