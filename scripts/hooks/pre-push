#!/usr/bin/env bash
# Pre-push privacy guardrail for resume-optimizer.  See PRIVACY.md.
#
# Refuses a push that carries PII, UNLESS this repo is an opted-in private fork:
#   Enable tracked hooks (once):   git config core.hooksPath scripts/hooks
#   Allow PII in a private fork:   git config resumeopt.allowPII true
#
# Blocks when the outgoing commits either:
#   (a) add/modify tracked files under resumes/, source_material/, or
#       benchmarks/{ground_truth,results,external}/ (except READMEs and
#       *.example.* / .gitkeep templates), or
#   (b) contain a real email address or phone number in ANY changed text file
#       (the toolkit's own placeholder values — example.com, 123-456-7890, … —
#       are ignored).
# It FAILS CLOSED: if it cannot determine what is being pushed, it refuses.

remote_name="$1"
z40="0000000000000000000000000000000000000000"

# In an opted-in private fork this guard steps aside.
if [ "$(git config --bool resumeopt.allowPII 2>/dev/null)" = "true" ]; then
  exit 0
fi

EMAIL='[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}'
# 3-3-4 with REQUIRED separators → won't match ISO dates or run-together IDs.
PHONE='(\+?[0-9]{1,3}[ .-])?\(?[0-9]{3}\)?[ .-][0-9]{3}[ .-][0-9]{4}'

problems=""
nl=$'\n'

# Files that legitimately carry placeholder PII or are binary → not content-scanned.
is_safe_file() {
  case "$1" in
    *.example.md|*.example.yaml|README.md|*/README.md|.gitkeep|*/.gitkeep) return 0 ;;
    *.png|*.jpg|*.jpeg|*.gif|*.pdf|*.zip|*.gz|*.ico|*.svg) return 0 ;;
    *) return 1 ;;
  esac
}

scan_commit() {   # $1 = tip sha, $2 = newline/space-separated file list
  local sha="$1" files="$2" f content hit
  # (a) protected-directory files (allow READMEs + example templates + .gitkeep)
  local pii_files
  pii_files=$(printf '%s\n' $files \
    | grep -E '^(resumes|source_material|benchmarks/ground_truth|benchmarks/results|benchmarks/external)/' \
    | grep -Ev '(^|/)README\.md$|\.example\.(md|yaml)$|/\.gitkeep$')
  if [ -n "$pii_files" ]; then
    problems="${problems}${nl}  PII files being pushed:${nl}$(printf '%s\n' "$pii_files" | sed 's/^/    /')"
  fi
  # (b) content scan of every changed text file (skip templates/binaries)
  for f in $files; do
    is_safe_file "$f" && continue
    content=$(git show "$sha:$f" 2>/dev/null) || continue
    hit=$(printf '%s' "$content" | grep -Eio "$EMAIL" | grep -Eiv 'example\.(com|org|net)$' | grep -Eiv '^(you|git|user|name|first\.last|noreply)@' | head -1)
    [ -n "$hit" ] && problems="${problems}${nl}  email address in $f (e.g. $hit)"
    hit=$(printf '%s' "$content" | grep -Eo "$PHONE" | grep -Ev '123.456.7890|617.555.0100' | head -1)
    [ -n "$hit" ] && problems="${problems}${nl}  phone number in $f (e.g. $hit)"
  done
}

while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$z40" ] && continue   # branch deletion

  # Fail CLOSED: if remote_sha isn't a local commit, scan the whole pushed tree.
  if [ "$remote_sha" = "$z40" ] || ! git rev-parse -q --verify "${remote_sha}^{commit}" >/dev/null 2>&1; then
    files=$(git ls-tree -r --name-only "$local_sha") \
      || { echo "pre-push: cannot list tree; refusing (fail-closed)." >&2; exit 1; }
  else
    files=$(git diff --name-only "$remote_sha" "$local_sha") \
      || { echo "pre-push: cannot diff; refusing (fail-closed)." >&2; exit 1; }
  fi
  scan_commit "$local_sha" "$files"
done

if [ -n "$problems" ]; then
  {
    printf '\n\342\233\224  pre-push blocked — possible PII heading to "%s":%s\n' "$remote_name" "$problems"
    printf '\nIf this is YOUR PRIVATE fork (private origin), allow it once:\n'
    printf '    git config resumeopt.allowPII true\n'
    printf 'Otherwise keep these files local — they should not be pushed. See PRIVACY.md.\n\n'
  } >&2
  exit 1
fi
exit 0
