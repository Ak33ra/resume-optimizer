#!/usr/bin/env bash
# Scan all outgoing commit versions for private data. See PRIVACY.md.
set -u

remote_name="${1:?pre-push requires a remote name}"
root="$(git rev-parse --show-toplevel)" || exit 1
scanner="$root/scripts/privacy_check.py"

attested_remote="$(git config --get resumeopt.privateRemote 2>/dev/null || true)"
attested_url="$(git config --get resumeopt.privatePushUrl 2>/dev/null || true)"
actual_url="$(git remote get-url --push "$remote_name" 2>/dev/null || true)"
allow_pii="$(git config --bool resumeopt.allowPII 2>/dev/null || true)"

# The exception is scoped to one exact remote and its current push URL. This is
# a local attestation; git cannot independently prove a hosting provider's
# visibility setting.
if [ "$allow_pii" = "true" ] \
  && [ -n "$attested_remote" ] \
  && [ "$remote_name" = "$attested_remote" ] \
  && [ -n "$attested_url" ] \
  && [ "$actual_url" = "$attested_url" ]; then
  exit 0
fi

z40="0000000000000000000000000000000000000000"
blocked=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$z40" ] && continue
  output="$(python3 "$scanner" --outgoing "$local_sha" "$remote_sha" 2>&1)"
  status=$?
  if [ $status -ne 0 ]; then
    blocked=1
    printf '%s\n' "$output" >&2
  fi
done

if [ $blocked -ne 0 ]; then
  {
    printf '\npre-push blocked: possible private data is reachable from outgoing commits.\n'
    printf 'For an attested private remote, configure all three values from PRIVACY.md.\n'
  } >&2
  exit 1
fi
